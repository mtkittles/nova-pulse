# Zmienne środowiskowe LUPUS BETS.
# Skopiuj do .env.local i uzupełnij. NIGDY nie commituj prawdziwych wartości.
# W produkcji ustaw je w Vercel → Settings → Environment Variables.

# API bota Lupus na Oracle — server-side. Ustaw dla Production + Preview + Development.
ORACLE_API_URL=http://92.5.152.209:8088
ORACLE_API_KEY=

# Sekret do podpisu sesji JWT — server-side.
# Wygeneruj np.: openssl rand -base64 32
JWT_SECRET=

# Token bota Telegram do weryfikacji Telegram Login — server-side, SEKRET.
TELEGRAM_BOT_TOKEN=

# Nazwa bota (bez @) do Telegram Login Widget — PUBLICZNA (widoczna w przeglądarce).
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=lupus_bet_bot

# Twój numeryczny Telegram ID — panel admina + tier premium. Server-side.
ADMIN_TELEGRAM_ID=

# Lista Telegram ID z premium (CSV), np. "123,456". Server-side, opcjonalne.
PREMIUM_TELEGRAM_IDS=

# Klucz do POST /public-api/admin/refresh na Oracle (X-Admin-Key). Server-side, SEKRET.
ADMIN_API_KEY=

# Deep-link logowanie (jak gmgn.io): bot otwiera Telegram, callback do strony.
# Wymaga Upstash Redis (free tier, https://upstash.com). Server-side.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Wspólny sekret bot↔strona dla webhooka /api/auth/callback. Server-side, SEKRET.
BOT_CALLBACK_SECRET=
